# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 豆包 LLM
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=your-doubao-model-id

# 飞书 (技能依赖)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 聊天附件签名（独立于其它密钥，建议 openssl rand -hex 32）
CHAT_ATTACHMENT_SIGNING_SECRET=replace-with-a-dedicated-random-secret

# ---------- 附件正文提取（二选一或同时配置；未指定时优先扣子）----------
# 可选：coze | mcp，不填则自动：有 COZE_* 用扣子，否则用 MCP
CHAT_ATTACHMENT_EXTRACTOR=

# 扣子（推荐初期）：开放平台个人访问令牌 + 已发布为 API 的智能体 bot_id（控制台链接末尾数字串）
COZE_API_TOKEN=
COZE_BOT_ID=7622919157226635279
COZE_API_BASE=https://api.coze.cn
# 可选：发给智能体的提取指令（默认已内置中文提示）
COZE_ATTACHMENT_PROMPT=
# 可选：对话轮询超时（毫秒），默认 120000
COZE_CHAT_TIMEOUT_MS=120000

# Docling / MinerU MCP（可选回退或 CHAT_ATTACHMENT_EXTRACTOR=mcp 时使用）
DOCLING_MCP_URL=
DOCLING_MCP_TOOL_NAME=
MINERU_MCP_URL=
MINERU_MCP_TOOL_NAME=
